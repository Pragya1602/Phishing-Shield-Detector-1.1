 { "manifest_version": 3,
  "name": "Phishing Shield Detector",
  "version": "1.1",
  "description": "Analyzes URLs in real-time to detect potential phishing threats.",
  "permissions": [
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js"
: ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
